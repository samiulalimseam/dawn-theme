<style>
  .product-card {
    width: 310px;
    height: 275px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    background: white;
    border-radius: 5px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    padding: 20px;
    font-family: 'Helvetica Neue'
    , sans-serif;
    margin: 40px auto;
  }
  .content-top {
    display: flex;
    gap: 10px;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
  }

  .close-btn {
    position: absolute;
    top: 0;
    right: 0;
    font-size: 24px;
    border: none;
    background: transparent;
    cursor: pointer;
  }

  .product-content {
    display: flex;
    gap: 20px;
    width: 100%;
    height: 100%;
    align-items: flex-start;
    flex-direction: column;
  }

  .product-image img {
    width: 120px;
    height: 170px;
    border-radius: 5px;
    object-fit: cover;
  }
  .product-image {
    width: 120px;
    height: 170px;
  }

  .product-info {
    display: flex;
    gap: 10px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    max-height: 170px;
    overflow: hidden;
  }

  .product-title {
    font-family: Jost;
    font-weight: 300;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0;
    vertical-align: middle;

  }

  .product-price {
    font-family: Lustria;
    font-weight: 400;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0;
    vertical-align: middle;

  }

  .product-description {
    font-family: Jost;
    font-weight: 300;
    font-size: 14px;
    line-height: 110.00000000000001%;
    letter-spacing: -1%;

  }
  .product-title,
  .product-price,
  .product-description {
    margin-block-start: 0 !important;
    margin-block-end: 0 !important;
  }
  .add-to-cart {
    width: 100%;
    padding: 15px;
    background: black;
    color: white;
    border: none;
    font-size: 16px;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    transition: background 0.3s ease;
  }

  .add-to-cart:hover {
    background: #333;
  }

  .arrow {
    font-size: 18px;
  }

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.4);
    z-index: 999;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .modal-overlay {
    transition: opacity 0.3s ease;
  }

</style>
<div>
  <button id="openModalBtn">Open Modal</button>
  <div id="customModal" class="modal-overlay">
    <div class="product-card">
      <button class="close-btn" aria-label="Close modal">&times;</button>
      <div class="product-content">
        <div class="content-top">
          <div class="product-image">
            <img src="https://dyn-sa-3.myshopify.com/cdn/shop/files/71dqQQS8_qL.jpg?v=1729493474&width=823" alt="Orange Wide Leg" />
          </div>
          <div class="product-info">
            <p class="product-title">Orange Wide Leg</p>
            <p class="product-price">980,00€</p>
            <p class="product-description">
              This one-piece swimsuit is crafted from jersey featuring an allover micro Monogram motif in relief.
            </p>
          </div>
        </div>
        <button class="add-to-cart">
          ADD TO CART
          <span class="arrow">&#8594;</span>
        </button>
      </div>
    </div>
  </div>


</div>
<script>
  document.querySelector('.close-btn').addEventListener('click', function () {
    const modal = document.getElementById('customModal');
    modal.style.opacity = '0';
  setTimeout(() => {
  modal.style.display = 'none';
  }, 300);

  });
</script>

<script>
  const modal = document.getElementById('customModal');
  const openBtn = document.getElementById('openModalBtn');
  const closeBtn = document.querySelector('.close-btn');

  openBtn.addEventListener('click', () => {
    modal.style.display = 'flex';
    modal.style.opacity = '1';
  });

  closeBtn.addEventListener('click', () => {
    modal.style.display = 'none';
  });
</script>


{% schema %}
  {
    "name": "Custom Modal",
    "settings": [],
    "presets": [
      {
        "name": "Custom Modal",
        "category": "Custom"
      }
    ]
  }
{% endschema %}