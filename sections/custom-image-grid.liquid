{% stylesheet %}
  .echologyx-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .grid-title {
    font-family: Lustria;
    font-weight: 400;
    font-size: 36px;
    line-height: 120%;
    letter-spacing: 0px;
    vertical-align: middle;
  }
  .echologyx-card {
    position: relative;
    overflow: hidden;
  }
  .echologyx-card img {
    width: 100%;
    display: block;
  }
  header.page-width {
    padding-inline: 15px !important;
  }
  .echologyx-pointer {
    position: absolute;
    background: transparent;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    cursor: pointer;
    transition: transform 0.2s;
  }
  .echologyx-pointer:hover {
    transform: scale(1.1);
  }
  /* modal stylesheets */
  .product-card {
    width: 310px;
    height: 275px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    background: white;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    padding: 20px;
    font-family: 'Helvetica Neue', sans-serif;
    margin: 40px auto;
  }
  .content-top {
    display: flex;
    gap: 10px;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
  }

  .close-btn {
    position: absolute;
    top: 0;
    right: 0;
    font-size: 24px;
    border: none;
    background: transparent;
    cursor: pointer;
  }

  .product-content {
    display: flex;
    gap: 20px;
    width: 100%;
    height: 100%;
    align-items: flex-start;
    flex-direction: column;
  }

  .product-image img {
    width: 120px;
    height: 170px;
    object-fit: cover;
  }
  .product-image {
    width: 120px;
    height: 170px;
  }

  .product-info {
    display: flex;
    gap: 10px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
    max-height: 170px;
    overflow: hidden;
  }

  .product-title {
    font-family: Jost;
    font-weight: 300;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0;
    vertical-align: middle;
  }

  .product-price {
    font-family: Lustria;
    font-weight: 400;
    font-size: 16px;
    line-height: 120%;
    letter-spacing: 0;
    vertical-align: middle;
  }

  .product-description {
    font-family: Jost;
    font-weight: 300;
    font-size: 14px;
    line-height: 110.00000000000001%;
    letter-spacing: -1%;
  }
  .product-title,
  .product-price,
  .product-description {
    margin-block-start: 0 !important;
    margin-block-end: 0 !important;
  }
  .add-to-cart {
    width: 100%;
    padding: 15px;
    background: black;
    color: white;
    border: none;
    font-size: 16px;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    transition: background 0.3s ease;
  }

  .add-to-cart:hover {
    background: #333;
  }

  .arrow {
    font-size: 18px;
  }

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.4);
    z-index: 999;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .modal-overlay {
    transition: opacity 0.3s ease;
  }
{% endstylesheet %}

<div>
  <div
    style="display: none;"
    id="customModal"
    class="modal-overlay"
  >
    <div class="product-card">
      <button class="close-btn" aria-label="Close modal">&times;</button>
      <div class="product-content">
        <div class="content-top">
          <div class="product-image">
            <img
              src="https://dyn-sa-3.myshopify.com/cdn/shop/files/71dqQQS8_qL.jpg?v=1729493474&width=823"
              alt="Orange Wide Leg"
            >
          </div>
          <div class="product-info">
            <p class="product-title">Orange Wide Leg</p>
            <p class="product-price">980,00€</p>
            <p class="product-description">
              This one-piece swimsuit is crafted from jersey featuring an allover micro Monogram motif in relief.
            </p>
          </div>
        </div>
        <button class="add-to-cart">
          ADD TO CART
          <span class="arrow">&#8594;</span>
        </button>
      </div>
    </div>
  </div>
</div>
<div id="product-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50">
  <div class="modal-overlay"></div>
  <div class="modal-content modal" id="modal-content">
    <button id="modal-close" class="modal-button">&times;</button>
    <div id="modal-product-info" class="product-info">
      <!-- Product content -->
    </div>
    <button id="modal-atc" class="modal-action">Add to Cart</button>
  </div>
</div>

<div class="echologyx-section">
  <h2 class="grid-title">{{ section.settings.title }}</h2>

  <div class="echologyx-grid">
    {% for block in section.blocks %}
      {% assign product = block.settings.product %}
      <div class="echologyx-card">
        {% if block.settings.image %}
          <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ product.title }}">
        {% endif %}
        <button
          href="#"
          class="echologyx-pointer"
          data-product-title="{{ product.title | escape }}"
          data-product-id="{{ product.variants.first.id }}"
          data-product-image="{{ product.featured_image | image_url: width: 300 }}"
          data-product-price="{{ product.price | money }}"
          data-product-description="{{ product.description |  truncate: 55 }}"
          onclick="openModal(this)"
          style="top: {{ block.settings.pointer_y }}%; left: {{ block.settings.pointer_x }}%;"
        >
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="11" cy="11" r="11" fill="#F8F8F8" fill-opacity="0.9"/>
            <path d="M11.3457 7.04175V15.5033" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
            <path d="M7.11523 11.2725H15.5768" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {% endfor %}
  </div>
</div>

<script>
  const openModal = (el) => {
    try {
      console.log('open modal clicked');
      const title = el.dataset.productTitle;
      const image = el.dataset.productImage;
      const price = el.dataset.productPrice;
      const variantId = el.dataset.productId;
      const description = el.dataset.productDescription;
      const modal = document.getElementById('customModal');
      const openBtn = document.getElementById('openModalBtn');
      const closeBtn = modal.querySelector('.close-btn');
      const titleElem = modal.querySelector('.product-title');
      const imageElem = modal.querySelector('.product-image img');
      const priceElem = modal.querySelector('.product-price');
      const descriptionElem = modal.querySelector('.product-description');
      const addToCartBtn = modal.querySelector('.add-to-cart');
      async function triggerCartUpdate(cartData) {
        const cart = document.querySelector('cart-drawer');
        if (cart) {
          const empty_inner = cart.querySelector('.drawer__inner-empty');
          if (empty_inner) {
            empty_inner.classList.remove('drawer__inner-empty');
            cart.classList.remove('is-empty');
            console.log('empty cart layer removed');
          }
        }
        const res = await publish(PUB_SUB_EVENTS.cartUpdate, {
          source: 'external-script',
          cartData: cartData,
        });
        console.log('trigger cart update', res);
        return res;
      }
      async function updateAndOpen() {
        await triggerCartUpdate();
        const cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer) {
          cartDrawer.open();
        } else {
          alert('Added, enable cart drawer to see the changes instantly');
        }
      }
      if (titleElem && imageElem && priceElem && descriptionElem && addToCartBtn) {
        titleElem.textContent = title;
        imageElem.src = image;
        priceElem.textContent = price;
        descriptionElem.innerHTML = description;
        addToCartBtn.onclick = async () => {
          const prevAddToCartBtnInnerHTML = addToCartBtn.innerHTML;
          addToCartBtn.innerHTML = 'Adding...';
          fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ id: variantId, quantity: 1 }),
          })
            .then(() => {
              modal.style.display = 'none';
              const cartDrawer = document.querySelector('cart-drawer');
              if (cartDrawer) {
                updateAndOpen();
              } else {
                alert('Added, enable cart drawer to see the changes instantly');
              }
            })
            .catch((error) => {
              console.error('Error adding to cart:', error);
            })
            .finally(() => {
              addToCartBtn.innerHTML = prevAddToCartBtnInnerHTML;
            });
        };

        modal.style.display = 'flex';
        modal.style.opacity = '1';
        const closeModal = () => {
          console.log('close modal clicked');
          modal.style.opacity = '0';
          setTimeout(() => {
            modal.style.display = 'none';
          }, 300);
        };
        modal.querySelector('.close-btn').addEventListener('click', closeModal);
        const modalOverLays = document.querySelectorAll('.modal-overlay');
        if (modalOverLays.length) {
          modalOverLays.forEach((overlay) => {
            overlay.addEventListener('click', closeModal);
          });
        }
        closeBtn.addEventListener('click', closeModal);
      }
    } catch (error) {}
  };
</script>

{% schema %}
{
  "name": "Custom Grid image",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Sound in the wild"
    }
  ],
  "blocks": [
    {
      "type": "image-product",
      "name": "Grid Item",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Grid Image"
        },
        {
          "type": "range",
          "id": "pointer_x",
          "label": "Pointer X Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "pointer_y",
          "label": "Pointer Y Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Echologyx Image Grid",
      "category": "Custom"
    }
  ]
}
{% endschema %}
